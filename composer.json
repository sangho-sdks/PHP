{
  "name": "sangho/sdk",
  "description": "SDK officiel PHP pour l'API Sangho",
  "type": "library",
  "license": "MIT",
  "version": "1.0.0",
  "authors": [
    { 
      "name": "Sangho", 
      "email": "dev@sangho.com" 
    }
  ],
  "homepage": "https://docs.sangho.com",
  "require": {
    "php": ">=8.5",
    "guzzlehttp/guzzle": "^7.10",
    "ramsey/uuid": "^4.9"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "mockery/mockery": "^1.6"
  },
  "autoload": {
    "psr-4": {
      "Sangho\\": "lib/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Sangho\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "lint": "phpcs --standard=PSR12 lib/ tests/"
  },
  "config": {
    "sort-packages": true
  },
  "support": {
    "source": "https://github.com/sangho-sdks/sangho-php",
    "issues": "https://github.com/sangho-sdks/sangho-php/issues"
  }
}
